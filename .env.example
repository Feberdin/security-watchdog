# Purpose: Example runtime configuration for local development and Docker deployment.
# Input/Output: Copy to `.env` and replace placeholder values with real secrets and paths.
# Important invariants: Keep this file free of real credentials; mounted paths should be read-only
# where possible, especially for Home Assistant config and the Docker socket.
# Debugging: If a service points to the wrong place, compare your `.env` with this file first.

APP_NAME=security-watchdog
ENVIRONMENT=production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=31337
RUN_EMBEDDED_SCHEDULER=false
PUID=1000
PGID=1000

DATABASE_URL=postgresql+psycopg://watchdog:watchdog@postgres:5432/watchdog
REDIS_URL=redis://redis:6379/0

GITHUB_TOKEN=replace-me
GITHUB_USERNAME=replace-me
GITHUB_INCLUDE_PRIVATE=true
GITHUB_ALERT_REPOSITORY=

UNRAID_DOCKER_ENABLED=true
UNRAID_DOCKER_HOST=unix:///var/run/docker.sock
UNRAID_VERIFY_TLS=false

HOMEASSISTANT_SCAN_ENABLED=true
HOMEASSISTANT_CONFIG_PATH=/opt/homeassistant-config
HOMEASSISTANT_CORE_COMPONENTS_PATH=/opt/homeassistant-core/components
HOMEASSISTANT_REMOTE_ENABLED=false
HOMEASSISTANT_REMOTE_BASE_URL=
HOMEASSISTANT_REMOTE_TOKEN=
HOMEASSISTANT_REMOTE_VERIFY_TLS=true
HOMEASSISTANT_REMOTE_TIMEOUT_SECONDS=15

AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

EMAIL_ENABLED=false
EMAIL_FROM=watchdog@example.local
EMAIL_TO=
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false

SLACK_WEBHOOK_URL=
